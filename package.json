{
  "name": "@viivue/atomic-css",
  "version": "1.2.5",
  "description": "⚛️ Customizable Atomic CSS Framework.",
  "main": "./dist/atomic.min.css",
  "style": "./dist/atomic.min.css",
  "exports": {
    ".": {
      "style": "./dist/atomic.min.css",
      "default": "./dist/atomic.min.css"
    },
    "./scss/*": "./scss/*",
    "./dist/*": "./dist/*"
  },
  "engines": {
    "node": ">=16"
  },
  "bin": {
    "atomic-css": "./bin/build.js"
  },
  "files": [
    "bin",
    "scss",
    "dist"
  ],
  "scripts": {
    "sass": "sass scss:css --no-source-map",
    "sass:watch": "sass scss:css -w --no-source-map",
    "sass:build": "sass scss/_build.scss:dist/atomic.css --no-source-map",
    "optimize": "csso dist/atomic.css --output dist/atomic.min.css --stat",
    "dev": "sass scss:css scss/_build.scss:dist/atomic.css -w --no-source-map",
    "prod": "npm run sass:build && npm run optimize"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viivue/atomic-css.git"
  },
  "keywords": [
    "atomic-css",
    "customizable-atomic-css",
    "viivue"
  ],
  "author": {
    "name": "viivuedev",
    "url": "https://github.com/viivue"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/viivue/atomic-css/issues"
  },
  "homepage": "https://github.com/viivue/atomic-css",
  "dependencies": {
    "csso": "^5.0.0",
    "sass": "^1.51.0"
  },
  "devDependencies": {
    "csso-cli": "^4.0.2"
  }
}
